# API Key de Aluri (requerido)
ALURI_API_KEY=aluri_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# URL de la API (opcional, default: https://aluri.co/api)
ALURI_API_URL=https://aluri.co/api

# Números autorizados para usar el bot (opcional)
# Si está vacío, cualquier número puede usar el bot
# Formato: código país + número, separados por coma
# Ejemplo: 573001234567,573009876543
NUMEROS_AUTORIZADOS=
