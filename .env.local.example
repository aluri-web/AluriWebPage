# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Agente de Contratos (Flask, external service)
NEXT_PUBLIC_AGENT_CONTRATOS_URL=https://your-agent-contratos.onrender.com

# AWS S3 Configuration (for property photos storage)
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your_bucket_name

# Note: Copy this file to .env.local and fill in your actual values
# Get these from your Supabase project settings: https://app.supabase.com
# Get AWS credentials from: https://console.aws.amazon.com/iam
