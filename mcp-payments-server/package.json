{
  "name": "mcp-aluri-server",
  "version": "2.0.0",
  "description": "MCP Server para todas las APIs de Aluri: préstamos, pagos, propietarios, inversionistas y usuarios",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:remote": "node dist/server.js",
    "dev": "tsx src/index.ts",
    "dev:remote": "tsx src/server.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "express": "^5.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
